# NewsAPI.org key — https://newsapi.org/account
NEWS_API_KEY=your_newsapi_key_here

# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API key for relevance filtering
OPENAI_API_KEY=your_openai_api_key_here

# Short URL base (override for local dev)
SHORT_URL_BASE=http://localhost:3000

# Rails secret key base (generate with: openssl rand -hex 64)
SECRET_KEY_BASE=change_me_generate_with_openssl_rand_hex_64
