<% content_for :title, "#{@article.title.truncate(80)} — Corrupted Pigs" %>

<% content_for :head do %>
  <!-- Open Graph / Telegram link preview -->
  <meta property="og:type"        content="article">
  <meta property="og:site_name"   content="Corrupted Pigs">
  <meta property="og:title"       content="<%= html_escape(@article.title) %>">
  <meta property="og:description" content="<%= html_escape(@article.description.to_s.truncate(200)) %>">
  <meta property="og:url"         content="<%= article_url(public_id: @article.public_id) %>">
  <% if @article.published_at %>
    <meta property="article:published_time" content="<%= @article.published_at.iso8601 %>">
  <% end %>
  <% if @article.image_url.present? %>
    <meta property="og:image"       content="<%= @article.image_url %>">
    <meta property="og:image:width" content="1200">
    <meta name="twitter:card"       content="summary_large_image">
    <meta name="twitter:image"      content="<%= @article.image_url %>">
  <% else %>
    <meta name="twitter:card"       content="summary">
  <% end %>
  <meta name="twitter:title"       content="<%= html_escape(@article.title) %>">
  <meta name="twitter:description" content="<%= html_escape(@article.description.to_s.truncate(200)) %>">

  <!-- Fonts (matching cpigs-game-prototype) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bangers&family=Inter:wght@400;500;600;700&family=Russo+One&display=swap" rel="stylesheet">

  <style>
    /* ── Reset ─────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Design tokens (mirrors index.css from prototype) ──── */
    :root {
      --bg:        hsl(270, 59%, 10%);
      --fg:        hsl(264, 20%, 95%);
      --border:    hsl(270, 59%, 25%);
      --card-bg:   hsl(270, 59%, 15%);
      --primary:   #FF33BB;
      --secondary: #F4B625;
      --muted-fg:  hsl(271, 15%, 65%);
      --radius:    12px;
      --font-sans:    'Inter', sans-serif;
      --font-heading: 'Russo One', sans-serif;
      --font-display: 'Bangers', cursive;
    }

    /* ── Base ───────────────────────────────────────────────── */
    html, body {
      min-height: 100vh;
      background-color: var(--bg);
      color: var(--fg);
      font-family: var(--font-sans);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ── Background effects ─────────────────────────────────── */
    .bg-noise {
      position: fixed; inset: 0;
      pointer-events: none; z-index: 0;
      opacity: 0.05;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }
    .scanline {
      position: fixed; left: 0; width: 100%; height: 100px;
      pointer-events: none; z-index: 1;
      background: linear-gradient(0deg, transparent 0%, rgba(255,51,187,0.08) 50%, transparent 100%);
      opacity: 0.3;
      animation: scanline 8s linear infinite;
    }
    @keyframes scanline {
      0%   { transform: translateY(-100vh); }
      100% { transform: translateY(100vh);  }
    }
    .orb-pink {
      position: fixed; top: -10%; left: -10%;
      width: 40%; height: 40%;
      border-radius: 50%;
      background: rgba(255, 51, 187, 0.15);
      filter: blur(120px);
      pointer-events: none; z-index: 0;
    }
    .orb-gold {
      position: fixed; bottom: -10%; right: -10%;
      width: 50%; height: 50%;
      border-radius: 50%;
      background: rgba(244, 182, 37, 0.07);
      filter: blur(150px);
      pointer-events: none; z-index: 0;
    }
    .grid-bg {
      position: fixed; inset: 0;
      pointer-events: none; z-index: 0;
      opacity: 0.15;
      background-image:
        linear-gradient(rgba(255,51,187,0.2) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,51,187,0.2) 1px, transparent 1px);
      background-size: 40px 40px;
      transform: perspective(1000px) rotateX(60deg) translateY(100px) scale(2.5);
      transform-origin: bottom center;
    }

    /* ── Layout ─────────────────────────────────────────────── */
    .page {
      position: relative; z-index: 10;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }

    /* ── Card ───────────────────────────────────────────────── */
    .card {
      width: 100%;
      max-width: 640px;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: 0 0 40px rgba(255, 51, 187, 0.12);
    }

    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1.25rem;
      border-bottom: 1px solid var(--border);
      background: rgba(255, 51, 187, 0.06);
    }
    .card-header .brand {
      font-family: var(--font-display);
      font-size: 1.4rem;
      color: var(--primary);
      text-shadow: 0 0 10px var(--primary), 0 0 20px var(--primary);
      letter-spacing: 2px;
    }
    .badge {
      font-family: var(--font-sans);
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
      background: rgba(244, 182, 37, 0.15);
      border: 1px solid rgba(244, 182, 37, 0.3);
      color: var(--secondary);
    }

    .card-image {
      width: 100%;
      max-height: 280px;
      overflow: hidden;
      border-bottom: 1px solid var(--border);
    }
    .card-image img {
      width: 100%;
      height: 280px;
      object-fit: cover;
      display: block;
      filter: brightness(0.92);
    }

    .card-body {
      padding: 1.5rem 1.25rem;
    }

    .article-title {
      font-family: var(--font-heading);
      font-size: 1.25rem;
      line-height: 1.35;
      color: var(--fg);
      margin-bottom: 1rem;
    }

    .article-description {
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--muted-fg);
      margin-bottom: 1.5rem;
    }

    .article-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.8rem;
      color: var(--secondary);
      margin-bottom: 1.5rem;
    }
    .article-meta .dot { color: var(--border); }

    .cta-button {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: transparent;
      border: 2px solid var(--primary);
      color: var(--primary);
      font-family: var(--font-heading);
      font-size: 0.95rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      text-decoration: none;
      padding: 0.65rem 1.4rem;
      border-radius: var(--radius);
      cursor: pointer;
      transition: background 0.2s, box-shadow 0.2s, color 0.2s;
      box-shadow: 0 0 10px rgba(255,51,187,0.2);
    }
    .cta-button:hover {
      background: var(--primary);
      color: #fff;
      box-shadow: 0 0 20px rgba(255,51,187,0.5);
    }

    .card-footer {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      padding: 0.75rem 1.25rem;
      border-top: 1px solid var(--border);
      font-size: 0.72rem;
      color: var(--muted-fg);
    }
    .card-footer a {
      color: var(--muted-fg);
      text-decoration: none;
      transition: color 0.15s;
    }
    .card-footer a:hover { color: var(--primary); }
  </style>
<% end %>

<!-- Background layers -->
<div class="bg-noise"></div>
<div class="scanline"></div>
<div class="orb-pink"></div>
<div class="orb-gold"></div>
<div class="grid-bg"></div>

<div class="page">
  <article class="card">
    <header class="card-header">
      <span class="brand">CORRUPTED PIGS</span>
      <span class="badge"><%= @article.language.upcase %></span>
    </header>

    <% if @article.image_url.present? %>
      <div class="card-image">
        <img src="<%= @article.image_url %>" alt="<%= html_escape(@article.title) %>" loading="lazy">
      </div>
    <% end %>

    <div class="card-body">
      <h1 class="article-title"><%= @article.title %></h1>

      <% if @article.description.present? %>
        <p class="article-description"><%= @article.description.truncate(400) %></p>
      <% end %>

      <div class="article-meta">
        <% if @article.source_name.present? %>
          <span><%= @article.source_name %></span>
          <span class="dot">·</span>
        <% end %>
        <% if @article.published_at.present? %>
          <time datetime="<%= @article.published_at.iso8601 %>">
            <%= @article.published_at.strftime("%b %-d, %Y") %>
          </time>
        <% end %>
      </div>

      <a href="<%= @article.url %>" target="_blank" rel="noopener noreferrer" class="cta-button">
        Read full article ↗
      </a>
    </div>

    <footer class="card-footer">
      <a href="https://corruptedpigs.com">corruptedpigs.com</a>
      <span>·</span>
      <span>cpigs.to</span>
    </footer>
  </article>
</div>
